{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Verbum Analyze Response",
  "type": "object",
  "required": [
    "errors",
    "corrected_text",
    "unmapped",
    "drills",
    "category_stats",
    "grammar_score",
    "analysis_status"
  ],
  "properties": {
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["span", "category", "rule_id", "severity", "correction", "confidence"],
        "properties": {
          "span": {
            "type": "object",
            "required": ["start", "end", "text"],
            "properties": {
              "start": { "type": "number" },
              "end": { "type": "number" },
              "text": { "type": "string" }
            }
          },
          "category": { "type": "string" },
          "rule_id": { "type": "string" },
          "severity": { "type": "number", "minimum": 1, "maximum": 3 },
          "correction": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "corrected_text": { "type": "string" },
    "unmapped": { "type": "array" },
    "drills": { "type": "array" },
    "category_stats": { "type": "array" },
    "grammar_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "analysis_status": { "type": "string", "enum": ["ok", "degraded"] },
    "comparison": {
      "type": "object",
      "properties": {
        "previous_error_count": { "type": "number" },
        "current_error_count": { "type": "number" },
        "fixed_rule_ids": { "type": "array", "items": { "type": "string" } },
        "remaining_rule_ids": { "type": "array", "items": { "type": "string" } },
        "new_rule_ids": { "type": "array", "items": { "type": "string" } },
        "score_delta": { "type": "number" }
      }
    }
  }
}
